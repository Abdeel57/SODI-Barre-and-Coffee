generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  phone         String?
  passwordHash  String
  role          Role           @default(STUDENT)
  pushToken     String?
  gender        Gender?
  birthDate     DateTime?
  createdAt     DateTime       @default(now())
  bookings      Booking[]
  subscription  Subscription?
  payments      Payment[]
  healthProfile HealthProfile?
  coachClasses  Class[]        @relation("CoachClasses")
}

model HealthProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  hasSurgeries          Boolean  @default(false)
  surgeriesDetail       String?
  isPregnant            Boolean  @default(false)
  pregnancyWeeks        Int?
  bloodType             String?
  emergencyContactName  String?
  emergencyContactPhone String?
  allergies             String?
  injuries              String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Class {
  id          String    @id @default(cuid())
  name        String
  instructor  String
  dayOfWeek   Int       // 0=Dom 1=Lun ... 6=Sáb
  startTime   String    // "09:00"
  durationMin Int       @default(55)
  maxCapacity Int       @default(12)
  isActive    Boolean   @default(true)
  coachId     String?
  bookings    Booking[]
  coach       User?     @relation("CoachClasses", fields: [coachId], references: [id], onDelete: SetNull)
}

model Booking {
  id        String        @id @default(cuid())
  userId    String
  classId   String
  date      DateTime
  status    BookingStatus @default(CONFIRMED)
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id])
  class     Class         @relation(fields: [classId], references: [id])

  @@unique([userId, classId, date])
}

model Package {
  id            String         @id @default(cuid())
  name          String
  classCount    Int?           // null = ilimitado
  validDays     Int
  priceMXN      Float
  isActive      Boolean        @default(true)
  subscriptions Subscription[]
}

model Subscription {
  id          String   @id @default(cuid())
  userId      String   @unique
  packageId   String
  classesLeft Int?     // null = ilimitado
  expiresAt   DateTime
  isActive    Boolean  @default(true)
  user        User     @relation(fields: [userId], references: [id])
  package     Package  @relation(fields: [packageId], references: [id])
}

model Payment {
  id          String        @id @default(cuid())
  userId      String
  packageId   String
  amountMXN   Float
  mpPaymentId String        @unique
  status      PaymentStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id])
}

enum Role {
  STUDENT
  ADMIN
  COACH
}

enum Gender {
  FEMALE
  MALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  ATTENDED
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}
