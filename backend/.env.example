# ── Base de datos ──────────────────────────────────────────────────────────────
# Railway la genera automáticamente al agregar el servicio PostgreSQL
DATABASE_URL="postgresql://user:pass@host:5432/railway"

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Correr DOS veces — uno para cada secret
JWT_SECRET="string_random_128_chars_hex"
JWT_REFRESH_SECRET="otro_string_random_128_chars_hex"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── URLs ───────────────────────────────────────────────────────────────────────
FRONTEND_URL="https://tu-app.railway.app"
BACKEND_URL="https://tu-app.railway.app"
PORT=3000
NODE_ENV="production"

# ── MercadoPago ────────────────────────────────────────────────────────────────
# Obtener en: mercadopago.com.mx/developers → Tu aplicación → Credenciales
MP_ACCESS_TOKEN="APP_USR-xxxxxxxxxxxxxxxx"
MP_WEBHOOK_SECRET="tu_webhook_secret"

# ── Web Push VAPID ─────────────────────────────────────────────────────────────
# Generar con: cd backend && npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="BxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxA"
VAPID_PRIVATE_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
VAPID_EMAIL="mailto:admin@tudominio.com"
